# SCQ Platform Environment Variables (Session 05)
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=8h

# Server
PORT=3001

# Rate limiting - auth endpoint
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# Rate limiting - agent endpoints
RATE_LIMIT_AGENT_WINDOW_MS=60000
RATE_LIMIT_AGENT_MAX=30

# Input validation
MAX_MESSAGE_LENGTH=2000
MAX_TEDD_MESSAGE_LENGTH=8000

# Cross-agent context (Session 05)
MAX_SCQ_FIELD_LENGTH=500

# HITL threshold (Session 05)
# Tedd sessions with average score below this value are flagged for professor review
HITL_SCORE_THRESHOLD=3.0
