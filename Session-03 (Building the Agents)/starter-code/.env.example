# SCQ Platform - Environment Variables (End of Session 03)
# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic API Key (required for all three agents)
ANTHROPIC_API_KEY=your-api-key-here

# JWT configuration (in server/.env)
JWT_SECRET=replace-with-32-plus-character-random-string
JWT_EXPIRY=8h

# Express server port
PORT=3001

# SQLite database path (relative to project root)
DB_PATH=data/scq.db

# Test user credentials (used by tests/test_end_to_end.py only)
TEST_STUDENT_EMAIL=test-student@hult.edu
TEST_STUDENT_PASS=TestPass123!
TEST_PROFESSOR_EMAIL=test-professor@hult.edu
TEST_PROFESSOR_PASS=TestPass123!

# Prompt version overrides (optional - defaults to 'current' if not set)
MATTEO_PROMPT_VERSION=current
JULI_PROMPT_VERSION=current
TEDD_PROMPT_VERSION=current
