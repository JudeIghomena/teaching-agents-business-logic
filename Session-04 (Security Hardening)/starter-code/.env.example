# SCQ Platform - Environment Variables (End of Session 04)
# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic API Key (required for all three agents)
ANTHROPIC_API_KEY=your-api-key-here

# JWT configuration
JWT_SECRET=replace-with-32-plus-character-random-string
JWT_EXPIRY=8h

# Express server port
PORT=3001

# SQLite database path (relative to project root)
DB_PATH=data/scq.db

# Rate limiting - auth endpoint (IP-based)
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# Rate limiting - agent endpoints (user-based)
RATE_LIMIT_AGENT_WINDOW_MS=60000
RATE_LIMIT_AGENT_MAX=30

# Input validation
MAX_MESSAGE_LENGTH=2000
MAX_TEDD_MESSAGE_LENGTH=8000

# Test user credentials (used by tests/ only - never used in production)
TEST_STUDENT_EMAIL=test-student@hult.edu
TEST_STUDENT_PASS=TestPass123!
TEST_PROFESSOR_EMAIL=test-professor@hult.edu
TEST_PROFESSOR_PASS=TestPass123!

# Prompt version overrides (optional - defaults to 'current' if not set)
MATTEO_PROMPT_VERSION=current
JULI_PROMPT_VERSION=current
TEDD_PROMPT_VERSION=current
