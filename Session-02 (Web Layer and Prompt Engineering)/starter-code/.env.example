# SCQ Platform - Environment Variables
# Copy this file to .env and fill in your values
# Never commit the .env file - it is in .gitignore

# Anthropic API key - get one at console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# JWT secret for signing tokens - must be at least 32 characters
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars

# JWT token lifetime (8h means tokens expire after 8 hours)
JWT_EXPIRY=8h

# Express server port
PORT=3001

# Path to the SQLite database file (relative to server/ folder)
DB_PATH=../data/scq.db
