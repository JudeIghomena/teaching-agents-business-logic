# SCQ Platform Environment Variables (Session 06 - Production)
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT - use a 64-character random hex string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_64_char_random_hex_string
JWT_EXPIRES_IN=8h

# Server
PORT=3001
# Required in production - must be your frontend domain URL (e.g. https://your-frontend.com)
# If missing in production, the server will exit on startup
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Database - in production, set to the Railway Volume mount path
# Example production value: /data/scq.db
DB_PATH=./data/scq.db

# Rate limiting - auth endpoint
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# Rate limiting - agent endpoints
RATE_LIMIT_AGENT_WINDOW_MS=60000
RATE_LIMIT_AGENT_MAX=30

# Input validation
MAX_MESSAGE_LENGTH=2000
MAX_TEDD_MESSAGE_LENGTH=8000

# Cross-agent context (Session 05)
MAX_SCQ_FIELD_LENGTH=500

# HITL threshold (Session 05)
# Tedd sessions with average score below this value are flagged for professor review
HITL_SCORE_THRESHOLD=3.0

# Token budget (Session 06)
# Per-student cumulative token limit across all agents in a session
# Default 50000 tokens supports approximately 30-40 turns across Matteo, Juli, and Tedd
TOKEN_BUDGET_PER_USER=50000
